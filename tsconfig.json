{
  "compilerOptions": {
    "types": ["node"],
    "target": "ES2020",
    "module": "Node16",
    "resolveJsonModule": true,
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": "./src"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}